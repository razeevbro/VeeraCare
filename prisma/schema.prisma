generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  ADMIN
}

enum PortalAccountType {
  WORKER
  EMPLOYER
}

enum ServiceNeeded {
  HOUSEMAID
  HOUSE_CLEANER
  TECHNICIAN
  CONSTRUCTION
  EVENT
  SECURITY_PERSONNEL
  NANNY_BABYSITTER
  ELDERLY_CARETAKER
  PERSONAL_COOK
  PRIVATE_DRIVER
  DEEP_CLEANING
  JANITORIAL_STAFF
  PLUMBER
  ELECTRICIAN
  GARDENER_LANDSCAPER
  GENERAL_LABORER
  MASON
  CARPENTER
  PAINTER
  WAITSTAFF_CATERING
  BARTENDER
  EVENT_SETUP_CREW
  GENERAL_SECURITY_GUARD
  VIP_SECURITY
  BOUNCER
  OFFICE_BOY_PEON
  RECEPTIONIST
  DELIVERY_COURIER
}

enum CtaInquiryType {
  HIRING
  WORKER
}

model User {
  id                 String            @id @default(cuid())
  email              String            @unique
  passwordHash       String
  name               String?
  phone              String?
  portalAccountType  PortalAccountType @default(EMPLOYER)
  role               Role              @default(CLIENT)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model StaffRequest {
  id             String          @id @default(cuid())
  inquiryType    CtaInquiryType  @default(HIRING)
  name           String
  phone          String
  email          String
  serviceNeeded  ServiceNeeded
  availability   String?
  message        String
  sourcePath     String?
  createdAt      DateTime        @default(now())

  @@index([createdAt])
  @@index([serviceNeeded])
  @@index([email])
  @@index([inquiryType])
}

model CmsService {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String
  imageUrl    String
  imageAlt    String?
  badges      Json?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([order])
  @@index([title])
}

model CmsIndustry {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  gradient  String
  iconName  String
  body      String
  jobs      Json
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([title])
}
